    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "autoprefixer": "^10.4.20",
    "@opennextjs/cloudflare": "^1.19.3",
    "postcss": "^8.5.1",
