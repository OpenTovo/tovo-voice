{
  "name": "tovo-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "biome format --write package.json pnpm-workspace.yaml tsconfig.json turbo.json .vscode apps packages/ui --files-ignore-unknown=true",
    "format:check": "biome format package.json pnpm-workspace.yaml tsconfig.json turbo.json .vscode apps packages/ui --files-ignore-unknown=true",
    "format:js": "biome format --write apps packages/ui --files-ignore-unknown=true",
    "format:all": "biome format --write package.json pnpm-workspace.yaml tsconfig.json turbo.json .vscode apps packages/ui --files-ignore-unknown=true",
    "lint:check": "turbo lint",
    "lint:fix": "pnpm --filter landing lint:fix && pnpm --filter web lint:fix && pnpm --filter @workspace/ui lint:fix",
    "typecheck": "turbo check-types",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "build:landing": "cd apps/landing && pnpm build",
    "dev:landing": "cd apps/landing && pnpm dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.5",
    "typescript": "5.7.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,json}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@dotenvx/dotenvx>picomatch": "4.0.4",
      "@aws-sdk/xml-builder>fast-xml-parser": "5.7.1",
      "flatted": "3.4.2",
      "lint-staged>picomatch": "4.0.4",
      "lint-staged>yaml": "2.8.3",
      "lodash": "4.18.1",
      "mdast-util-to-hast": "13.2.1",
      "micromatch>picomatch": "2.3.2",
      "minimatch@10.2.4>brace-expansion": "5.0.5",
      "minimatch@3.1.5>brace-expansion": "1.1.13",
      "minimatch@8.0.7>brace-expansion": "2.0.3",
      "router@2.2.0>path-to-regexp": "8.4.2",
      "tinyglobby>picomatch": "4.0.4",
      "yaml": "2.8.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}